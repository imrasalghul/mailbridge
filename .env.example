# Node App Configuration
PORT=3090
SMTP_RELAY_PORT=2525
SMTP_RELAY_SOCKET_TIMEOUT_MS=120000
MAILBRIDGE_VERBOSE_LOGGING=true
MAILBRIDGE_HOSTNAME=mailbridge.example.com
QUEUE_MAX_ATTEMPTS=20

# Optional in-container Cloudflare Tunnel
# Set CLOUDFLARED_ENABLED=true only if this container should run cloudflared itself.
# Use the tunnel token from Cloudflare Dashboard > Networking > Tunnels.
CLOUDFLARED_ENABLED=false
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_LOGLEVEL=info

# Security - Make sure this matches the WEBHOOK_SECRET in your Cloudflare Worker variables
WEBHOOK_SECRET=WEBHOOK

# Local Mail Server Configuration (inbound destination)
EXCHANGE_HOST=MAIL_HOST
EXCHANGE_PORT=25

# Outbound SendGrid Configuration (Exchange/LAN -> Internet)
SENDGRID_API_KEY=SG.your_api_key
SENDGRID_FROM_FALLBACK=relay@example.com
SMTP_RELAY_VERBOSE_LOGGING=true
SMTP_RELAY_INJECT_HEADERS=true

# SpamAssassin Config (internal to container)
SPAMD_HOST=127.0.0.1
SPAMD_PORT=783
SPAMC_TIMEOUT_MS=10000
SPAMC_FAIL_OPEN=false
SA_BLOCK_THRESHOLD=12
SA_QUESTIONABLE_THRESHOLD=5
SPAM_SCL_SCORE=9
SPAM_SUBJECT_TAG=[SPAM]

# AI Secondary Screening (OpenAI compatible servers)
AI_API_KEY=AIKEY
AI_MAX_INPUT_CHARS=20000

# Optional AbuseIPDB sender IP reputation filter (inbound webhook flow)
ABUSEIPDB_ENABLED=true
ABUSEIPDB_API_KEY=
ABUSEIPDB_BLOCK_SCORE=75
ABUSEIPDB_MAX_AGE_DAYS=90
